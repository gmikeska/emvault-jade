{
  "name": "@emvault/jade",
  "version": "0.1.0",
  "description": "Dependency-free Blockstream Jade WebSerial (USB) driver for the browser — Bitcoin PSBT signing and device onboarding over Jade's CBOR-RPC protocol.",
  "license": "MIT OR Apache-2.0",
  "author": "Greg Mikeska (https://github.com/gmikeska)",
  "type": "module",
  "scripts": {
    "test": "node --test"
  },
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/index.js",
    "src/index.d.ts",
    "src/jade-rpc.js",
    "src/cbor.js",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gmikeska/emvault-jade.git"
  },
  "homepage": "https://github.com/gmikeska/emvault-jade#readme",
  "bugs": {
    "url": "https://github.com/gmikeska/emvault-jade/issues"
  },
  "keywords": [
    "bitcoin",
    "jade",
    "blockstream",
    "webserial",
    "hardware-wallet",
    "psbt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
